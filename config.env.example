# Copy this file to config.env and fill in your details
# docker cp config.env.example config.env

# Your amateur radio callsign
CALLSIGN=AB1CDE

# 6-character Maidenhead grid locator
LOCATOR=JJ00aa

# Latitude (positive = North, negative = South)
LAT=00.00

# Longitude (positive = East, negative = West)
LONG=00.00

# UTC offset in hours (e.g. +2, -5)
UTC_OFFSET=+2

# VOACAP propagation mode: CW=19 SSB=38 AM=49 WSPR=3 FT8=13 FT4=17
VOACAP_MODE=38

# Transmit power in Watts
VOACAP_POWER=100

# Callsign box background color (R,G,B)
CALLSIGN_BACKGROUND_COLOR=80,80,80

# Set to 1 to enable rainbow background (overrides color above)
CALLSIGN_BACKGROUND_RAINBOW=0

# Callsign text color (R,G,B)
CALLSIGN_COLOR=200,200,200

# FLRIG integration (leave as-is if not using FLRIG)
FLRIG_HOST=localhost
FLRIG_PORT=12345
USE_FLRIG=0

# Set to 1 to use metric system
USE_METRIC=1
